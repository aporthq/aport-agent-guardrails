#!/usr/bin/env bash
# Test file read/write capabilities with local and API mode

set -e

# Skip test if taking too long (Makefile runs with timeout)
if [ -n "$SKIP_SLOW_TESTS" ]; then
    echo "⏭️  Skipping slow file capabilities test"
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

echo "🧪 Testing File Read/Write Capabilities"
echo "========================================"
echo ""

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

pass_count=0
fail_count=0

function test_pass() {
    echo -e "${GREEN}✓ PASS:${NC} $1"
    ((pass_count++))
}

function test_fail() {
    echo -e "${RED}✗ FAIL:${NC} $1"
    ((fail_count++))
}

function test_section() {
    echo ""
    echo -e "${YELLOW}═══ $1 ═══${NC}"
    echo ""
}

# Create test passport with file capabilities
TEST_PASSPORT_FILE="/tmp/test-file-passport-$$.json"
cat > "$TEST_PASSPORT_FILE" << 'EOF'
{
  "passport_id": "test-file-caps",
  "agent_id": "test-file-caps",
  "kind": "template",
  "spec_version": "oap/1.0",
  "owner_id": "test@aport.io",
  "owner_type": "user",
  "assurance_level": "L0",
  "status": "active",
  "capabilities": [
    {"id": "data.file.read"},
    {"id": "data.file.write"}
  ],
  "limits": {
    "data.file.read": {
      "allowed_paths": ["/tmp/*", "/var/tmp/*"],
      "max_file_size_mb": 10
    },
    "data.file.write": {
      "allowed_paths": ["/tmp/*"],
      "max_file_size_mb": 5
    }
  },
  "regions": ["US"],
  "metadata": {
    "name": "File Capabilities Test Agent",
    "version": "1.0.0"
  },
  "never_expires": true,
  "created_at": "2026-03-01T00:00:00Z",
  "updated_at": "2026-03-01T00:00:00Z",
  "version": "1.0.0"
}
EOF

# Test files
TEST_READ_FILE="/tmp/test-read-$$.txt"
echo "test content" > "$TEST_READ_FILE"

test_section "Local Mode - File Read"

# Set passport file for guardrail script
export OPENCLAW_PASSPORT_FILE="$TEST_PASSPORT_FILE"

# Test 1: Allowed path should succeed
result=$("$ROOT_DIR/bin/aport-guardrail-bash.sh" read "{\"file_path\": \"$TEST_READ_FILE\"}" < /dev/null 2>&1)
if echo "$result" | grep -q '"allow": *true'; then
    test_pass "Read from allowed path (/tmp/)"
else
    test_fail "Read from allowed path (/tmp/) - Expected allow, got deny"
fi

# Test 2: Blocked path should fail
result=$("$ROOT_DIR/bin/aport-guardrail-bash.sh" read "{\"file_path\": \"/etc/passwd\"}" < /dev/null 2>&1)
if echo "$result" | grep -q '"allow": *false'; then
    test_pass "Read from blocked path (/etc/passwd) denied"
else
    test_fail "Read from blocked path (/etc/passwd) - Expected deny, got allow"
fi

# Test 3: Sensitive file pattern should be blocked
result=$("$ROOT_DIR/bin/aport-guardrail-bash.sh" read "{\"file_path\": \"/tmp/.env\"}" < /dev/null 2>&1)
if echo "$result" | grep -q '"allow": *false'; then
    test_pass "Sensitive file (.env) blocked by pattern"
else
    test_fail "Sensitive file (.env) - Expected deny, got allow"
fi

test_section "Local Mode - File Write"

# Test 4: Write to allowed path
result=$("$ROOT_DIR/bin/aport-guardrail-bash.sh" write "{\"file_path\": \"/tmp/test-write-$$.txt\", \"content\": \"test\"}" < /dev/null 2>&1)
if echo "$result" | grep -q '"allow": *true'; then
    test_pass "Write to allowed path (/tmp/)"
else
    test_fail "Write to allowed path (/tmp/) - Expected allow, got deny"
fi

# Test 5: Write to blocked path
result=$("$ROOT_DIR/bin/aport-guardrail-bash.sh" write "{\"file_path\": \"/etc/hosts\", \"content\": \"test\"}" < /dev/null 2>&1)
if echo "$result" | grep -q '"allow": *false'; then
    test_pass "Write to blocked path (/etc/hosts) denied"
else
    test_fail "Write to blocked path (/etc/hosts) - Expected deny, got allow"
fi

# Test 6: Edit should map to write policy
result=$("$ROOT_DIR/bin/aport-guardrail-bash.sh" edit "{\"file_path\": \"/tmp/test-edit-$$.txt\", \"old_string\": \"a\", \"new_string\": \"b\"}" < /dev/null 2>&1)
if echo "$result" | grep -q '"allow": *true'; then
    test_pass "Edit mapped to write policy correctly"
else
    test_fail "Edit mapping - Expected allow, got deny"
fi

test_section "API Mode - File Read/Write"

# Check if API is running
if ! curl -s "http://localhost:8787/health" > /dev/null 2>&1; then
    echo -e "${YELLOW}⚠ API not running at http://localhost:8787, skipping API tests${NC}"
else
    # Test 7: API mode - file read allowed path
    result=$(curl -s -X POST "http://localhost:8787/api/verify/policy/data.file.read.v1" \
        -H "Content-Type: application/json" \
        -d "{
            \"passport\": $(cat "$TEST_PASSPORT_FILE"),
            \"context\": {
                \"file_path\": \"$TEST_READ_FILE\"
            }
        }" < /dev/null 2>&1)

    if echo "$result" | jq -e '.decision.allow == true' > /dev/null 2>&1; then
        test_pass "API: Read from allowed path"
    else
        test_fail "API: Read from allowed path - Expected allow"
    fi

    # Test 8: API mode - file read blocked path
    result=$(curl -s -X POST "http://localhost:8787/api/verify/policy/data.file.read.v1" \
        -H "Content-Type: application/json" \
        -d "{
            \"passport\": $(cat "$TEST_PASSPORT_FILE"),
            \"context\": {
                \"file_path\": \"/etc/passwd\"
            }
        }" < /dev/null 2>&1)

    if echo "$result" | jq -e '.decision.allow == false' > /dev/null 2>&1; then
        test_pass "API: Read from blocked path denied"
    else
        test_fail "API: Read from blocked path - Expected deny"
    fi

    # Test 9: API mode - file write allowed path
    result=$(curl -s -X POST "http://localhost:8787/api/verify/policy/data.file.write.v1" \
        -H "Content-Type: application/json" \
        -d "{
            \"passport\": $(cat "$TEST_PASSPORT_FILE"),
            \"context\": {
                \"file_path\": \"/tmp/test-api-write.txt\",
                \"content\": \"test\"
            }
        }" < /dev/null 2>&1)

    if echo "$result" | jq -e '.decision.allow == true' > /dev/null 2>&1; then
        test_pass "API: Write to allowed path"
    else
        test_fail "API: Write to allowed path - Expected allow"
    fi

    # Test 10: API mode - file write blocked path
    result=$(curl -s -X POST "http://localhost:8787/api/verify/policy/data.file.write.v1" \
        -H "Content-Type: application/json" \
        -d "{
            \"passport\": $(cat "$TEST_PASSPORT_FILE"),
            \"context\": {
                \"file_path\": \"/etc/hosts\",
                \"content\": \"malicious\"
            }
        }" < /dev/null 2>&1)

    if echo "$result" | jq -e '.decision.allow == false' > /dev/null 2>&1; then
        test_pass "API: Write to blocked path denied"
    else
        test_fail "API: Write to blocked path - Expected deny"
    fi
fi

# Cleanup
rm -f "$TEST_PASSPORT_FILE" "$TEST_READ_FILE"

echo ""
echo "========================================"
echo -e "Test Results: ${GREEN}$pass_count passed${NC}, ${RED}$fail_count failed${NC}"
echo "========================================"

if [ $fail_count -gt 0 ]; then
    exit 1
fi
